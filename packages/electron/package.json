{
  "name": "@web-ai-ide/electron",
  "version": "1.0.0",
  "description": "Web AI IDE Desktop Application",
  "type": "module",
  "main": "dist-electron/main.js",
  "author": "HuiltSun",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build-with-timestamp.cjs"
  },
  "dependencies": {
    "electron-log": "^5.1.0",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.webaiide.app",
    "productName": "Web AI IDE",
    "directories": {
      "output": "release5"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "electronDist": "node_modules/electron/dist",
    "electronVersion": "30.5.1",
    "publish": null,
    "forceCodeSigning": false
  }
}
